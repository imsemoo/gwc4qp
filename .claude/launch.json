{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "gwc-site",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path'),m={'html':'text/html','css':'text/css','js':'application/javascript','png':'image/png','jpg':'image/jpeg','svg':'image/svg+xml','json':'application/json','ico':'image/x-icon','woff2':'font/woff2'};h.createServer((q,r)=>{let u=q.url.split('?')[0];if(u==='/')u='/index.html';const fp=p.join('.',u),ext=p.extname(fp).slice(1);f.readFile(fp,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');return}r.writeHead(200,{'Content-Type':m[ext]||'application/octet-stream','Access-Control-Allow-Origin':'*'});r.end(d)})}).listen(8080,()=>console.log('Server on 8080'))"],
      "port": 8080
    }
  ]
}
